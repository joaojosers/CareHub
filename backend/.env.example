# ─── CareHub Backend — Environment Variables ─────────────────────────────────
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development (Docker):
DATABASE_URL="postgresql://careuser:carepassword@localhost:5433/carehub_db?schema=public"
# Inside Docker network (container-to-container):
# DATABASE_URL="postgresql://careuser:carepassword@db:5432/carehub_db?schema=public"

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="1d"

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Sandbox token (development — no real money):
MP_ACCESS_TOKEN="TEST-your-sandbox-token-here"
# Production token (obtain from mercadopago.com.br/developers):
# MP_ACCESS_TOKEN="APP_USR-your-production-token-here"

# Webhook secret (configure in Mercado Pago developer panel):
MP_WEBHOOK_SECRET=""

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
